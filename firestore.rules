rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function deckDoc(deckId) {
      return get(/databases/$(database)/documents/decks/$(deckId));
    }

    function ownsDeck(deckId) {
      return signedIn()
        && exists(/databases/$(database)/documents/decks/$(deckId))
        && deckDoc(deckId).data.ownerId == request.auth.uid;
    }

    function publicDeck(deckId) {
      return exists(/databases/$(database)/documents/decks/$(deckId))
        && deckDoc(deckId).data.visibility == 'public';
    }

    function classReader(deckId) {
      return signedIn()
        && exists(/databases/$(database)/documents/decks/$(deckId))
        && deckDoc(deckId).data.keys().hasAny(['readerIds'])
        && request.auth.uid in deckDoc(deckId).data.readerIds;
    }

    function canReadDeck(deckId) {
      return publicDeck(deckId) || ownsDeck(deckId) || classReader(deckId);
    }

    match /users/{userId} {
      allow read, write: if isOwner(userId);
    }

    match /decks/{deckId} {
      allow read: if resource.data.visibility == 'public'
        || (signedIn() && resource.data.ownerId == request.auth.uid)
        || (signedIn()
            && resource.data.keys().hasAny(['readerIds'])
            && request.auth.uid in resource.data.readerIds);
      allow create: if signedIn() && request.resource.data.ownerId == request.auth.uid;
      allow update, delete: if signedIn() && resource.data.ownerId == request.auth.uid;

      match /cards/{cardId} {
        allow read: if canReadDeck(deckId);
        // Owners edit freely; class readers may update mastery/SRS fields while studying
        allow create, delete: if ownsDeck(deckId);
        allow update: if ownsDeck(deckId)
          || (classReader(deckId)
              && request.resource.data.diff(resource.data).affectedKeys()
                  .hasOnly(['mastery', 'nextReviewAt', 'lastStudiedAt']));
      }
    }

    match /studySessions/{sessionId} {
      allow create: if signedIn() && request.resource.data.userId == request.auth.uid;
      allow read: if signedIn() && resource.data.userId == request.auth.uid;
      allow update, delete: if false;
    }

    match /classes/{classId} {
      allow read: if signedIn();
      allow create: if signedIn()
        && request.resource.data.ownerId == request.auth.uid
        && request.auth.uid in request.resource.data.memberIds;
      allow update: if signedIn() && (
        resource.data.ownerId == request.auth.uid
        || (
          !(request.auth.uid in resource.data.memberIds)
          && request.auth.uid in request.resource.data.memberIds
          && request.resource.data.diff(resource.data).affectedKeys()
              .hasOnly(['memberIds'])
        )
      );
      allow delete: if signedIn() && resource.data.ownerId == request.auth.uid;
    }
  }
}
