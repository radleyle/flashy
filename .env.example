# Clerk
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# App URL (no trailing slash)
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Firebase client
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=flashcard-saas-cb092
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Firebase Admin (required for Clerk↔Firebase custom tokens + Stripe plan sync)
# Prefer a local file path (gitignored). On Vercel, use FIREBASE_SERVICE_ACCOUNT_JSON as one line.
FIREBASE_SERVICE_ACCOUNT_PATH=./your-project-firebase-adminsdk.json
# FIREBASE_SERVICE_ACCOUNT_JSON=
# FIREBASE_PROJECT_ID=
# FIREBASE_CLIENT_EMAIL=
# FIREBASE_PRIVATE_KEY=

# OpenRouter / AI
OPENROUTER_API_KEY=

# Stripe
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Support (shown in footer + Account)
NEXT_PUBLIC_SUPPORT_EMAIL=support@yourdomain.com
